{
  "name": "@laup/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "laup": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@laup/core": "workspace:*",
    "@laup/config-hub": "workspace:*",
    "@laup/claude-code": "workspace:*",
    "@laup/cursor": "workspace:*",
    "@laup/aider": "workspace:*"
  }
}
