{
  "name": "laup",
  "version": "0.0.0",
  "private": true,
  "description": "LLM Agent Unification Provider — monorepo root",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "pnpm run lint:md && pnpm run lint:machine",
    "lint:fix": "pnpm run lint:md:fix && pnpm run lint:yaml:fix && pnpm run lint:biome:fix && pnpm run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "prepare": "husky",
    "lint:biome": "biome check .",
    "lint:biome:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:frontmatter": "node scripts/lint-frontmatter.mjs",
    "lint:yaml": "node scripts/lint-yaml.mjs",
    "lint:yaml:fix": "node scripts/lint-yaml.mjs --fix",
    "lint:machine": "pnpm run lint:yaml && pnpm run lint:frontmatter && pnpm run lint:biome",
    "tutorial": "scripts/tutorial.sh",
    "quality:baseline": "node scripts/quality-baseline.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/cli": "^2.27.11",
    "@types/node": "^25.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,mdc}": [
      "markdownlint-cli2 --fix",
      "markdownlint-cli2",
      "node scripts/lint-frontmatter.mjs"
    ],
    "*.{yml,yaml}": [
      "node scripts/lint-yaml.mjs --fix",
      "node scripts/lint-yaml.mjs"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
