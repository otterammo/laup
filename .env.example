# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://laup:laup_dev@localhost:5432/laup

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Vault ───────────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
# Dev only — never use a plaintext token in production
VAULT_TOKEN=dev-root-token

# ─── LAUP CLI ────────────────────────────────────────────────────────────────
# Directory where laup stores its local state
LAUP_STATE_DIR=~/.laup

# Log level: debug | info | warn | error
LOG_LEVEL=info
